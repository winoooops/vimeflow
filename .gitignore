# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
dist-electron/
build/
out/
*.local

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# Environment
.env
.env.local
.env.*.local

# Superpowers plugin working directory
.superpowers/

# Lifeline and legacy harness review-loop artifacts
.lifeline-upsource-review/
.harness-github-review/

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store

# Tauri
src-tauri/target/
src-tauri/gen/
src-tauri/Cargo.lock

# TypeScript
*.tsbuildinfo

# Logs
logs/
*.log

# OS
Thumbs.db

# Python
*.py[cod]
__pycache__/

# Lifeline runtime files (generated per iteration, not source)
app_spec.md
feature_list.json
.feature_list_stamp.json
claude-progress.txt

# Lifeline agent artifacts (session summaries, scratch files)
SESSION_*_SUMMARY.md
NEXT_COMMIT.txt
BUG_FIX_VERIFICATION.md
COMPLETION_SUMMARY.md
COVERAGE.md
VISUAL_VERIFICATION.md

# Codex review output (local only)
.codex-reviews/

# Git worktrees (local per-agent checkouts)
.claude/worktrees/
.worktrees/

# Vimeflow runtime data (statusline sessions, etc.)
.vimeflow/

# Verification screenshots (testing artifacts)
feedback*.png
feedbacak*.png

# Lifeline sandbox shadow stubs (0-byte read-only files mirroring $HOME paths
# at the project root, created by claude-code's sandbox layer to deny
# path-traversal writes to user home).
/.bash_profile
/.bashrc
/.gitconfig
/.gitmodules
/.profile
/.ripgreprc
/.zprofile
/.zshrc
# .idea/ and .vscode/ above only match directories; cover the file form too.
/.idea
/.vscode
# 0-byte stubs that show up under .claude/ alongside the real subdirs.
/.claude/agents
/.claude/commands
/.claude/scheduled_tasks.lock
# Lifeline runtime config + scratch files.
/.claude_settings_cli.json
/handoff.md
/dyn_trait_test
