{
  "name": "vibm",
  "version": "0.1.0",
  "description": "VIBM - Coding agent conversation manager",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri:dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
    "tauri:build": "tauri build",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -b",
    "test": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "review": "bash scripts/review.sh",
    "review:fix": "bash scripts/review-fix.sh",
    "generate:bindings": "cd src-tauri && cargo test export_bindings && cd .. && prettier --write src/bindings/",
    "test:e2e:build": "cross-env VITE_E2E=1 npm run build && cd src-tauri && cargo build --features e2e-test,tauri/custom-protocol",
    "test:e2e": "wdio tests/e2e/core/wdio.conf.ts",
    "test:e2e:terminal": "wdio tests/e2e/terminal/wdio.conf.ts",
    "test:e2e:all": "npm run test:e2e && npm run test:e2e:terminal"
  },
  "keywords": [
    "tauri",
    "desktop",
    "ai",
    "agent",
    "conversation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@cspell/eslint-plugin": "^8",
    "@stylistic/eslint-plugin": "^4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4",
    "@vitest/coverage-v8": "^3.2.4",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "cross-env": "^10.1.0",
    "diff2html": "^3.4.56",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-import": "^2",
    "eslint-plugin-promise": "^7",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-regex": "^1",
    "eslint-plugin-storybook": "^0",
    "eslint-plugin-testing-library": "^7",
    "eslint-plugin-vitest": "^0",
    "globals": "^16",
    "husky": "^9",
    "jsdom": "^26",
    "lint-staged": "^15",
    "postcss": "^8",
    "prettier": "^3",
    "simple-git": "^3.33.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitest": "^3"
  }
}
