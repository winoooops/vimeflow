' ────────────────────────────────────────────────────────────────────
' ORCHESTRATION (private, lives in agent::adapter::base)
' ────────────────────────────────────────────────────────────────────

class "base::start_for<R: Runtime>" as StartFor <<pub(crate) fn>> #FFEFD5 {
  adapter: Arc<dyn AgentAdapter<R>>
  app: AppHandle<R>
  sid: String
  cwd: PathBuf
  state: AgentWatcherState
  --
  Result<(), String>
}

note right of StartFor
  <b>The orchestration body.</b>
  • debounce + notify watcher
  • WSL2 polling fallback
  • inline-init read
  • path-history diagnostics
  • transcript spawn via
    `state.start_or_replace(adapter, …)`
  • trust_root canonicalize-and-verify
  • constructs `WatcherHandle` with
    `_watcher: Some(watcher)`,
    `transcript_state: state.clone()`,
    `session_id: sid.clone()`
end note

DynImpl ..> StartFor : delegates

' ────────────────────────────────────────────────────────────────────
' LIFECYCLE TYPES (in base.rs; pub #[doc(hidden)] for tests)
' ────────────────────────────────────────────────────────────────────

class WatcherHandle <<struct>> #LightYellow {
  -_watcher: Option<RecommendedWatcher>
  -stop_flag: Arc<AtomicBool>
  -join_handle: Option<JoinHandle>
  -transcript_state: TranscriptState
  -session_id: String
  --
  +Drop::drop(&mut self)
  ' 1. drop(self._watcher.take()) — notify callbacks cease
  ' 2. stop_flag + poll-thread join
  ' 3. transcript_state.stop(&sid)
}

class AgentWatcherState <<struct>> #LightYellow {
  -watchers: Arc<Mutex<HashMap<String, WatcherHandle>>>
  +new() : Self
  +insert(sid: String, h: WatcherHandle)
  +remove(sid: &str) : bool
}

class TranscriptHandle <<struct>> #LightYellow {
  -stop_flag: Arc<AtomicBool>
  -join_handle: Option<JoinHandle>
  --
  +stop(self) ' joins
  +Drop::drop(&mut self) ' signals only
}

class TranscriptState <<struct>> #LightYellow {
  -watchers: Arc<Mutex<HashMap<String, TranscriptWatcher>>>
  +new() : Self
  +start_or_replace<R>(adapter, app, sid, path, cwd) : Result<TranscriptStartStatus, String>
  +stop(sid: &str) : Result<(), String>
}

enum TranscriptStartStatus <<enum>> {
  Started
  Replaced
  AlreadyRunning
}

note bottom of TranscriptState
  Tauri-managed (`lib.rs:.manage(TranscriptState::new())`).
  `start_or_replace` routes the spawn through
  `adapter.tail_transcript(…)` — keeps base
  uncoupled from any specific adapter.
end note

AgentWatcherState "1" *-- "*" WatcherHandle : owns
TranscriptState "1" *-- "*" TranscriptHandle : owns (via TranscriptWatcher)
WatcherHandle o-- TranscriptState : Arc-clone for Drop cascade
TranscriptState ..> TranscriptStartStatus : returns

StartFor ..> AgentWatcherState : inserts WatcherHandle
StartFor ..> TranscriptState : routes via start_or_replace
StartFor ..> AgentAdapter : calls hooks via &dyn

AgentAdapter ..> TranscriptHandle : tail_transcript returns

