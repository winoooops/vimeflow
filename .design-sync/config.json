{
  "projectId": "aee5efed-3941-4a76-8adb-5e31ba88da5f",
  "shape": "package",
  "pkg": "vibm",
  "globalName": "Vimeflow",
  "buildCmd": "npx vite build && cp dist/assets/index-*.css dist/assets/app-styles.css",
