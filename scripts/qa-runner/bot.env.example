# Bot GitHub identity for the QA runner — separates the runner's actions from yours.
# Copy to bot.env (gitignored) and fill in. DO NOT paste the token into chat —
# the runner reads it from this file. If bot.env is absent, the runner acts as
# your own gh account (backward-compatible).
#
# Create: a SEPARATE GitHub account, add it as a Write collaborator on
# winoooops/vimeflow, then make a fine-grained PAT on that account scoped to
# winoooops/vimeflow with: Contents = Read+Write, Pull requests = Read+Write
# (Metadata = Read auto). NOT admin.
GH_BOT_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
GH_BOT_USER=vimeflow-qa-bot
GH_BOT_EMAIL=youremail+qabot@example.com
