# Orchestrator (OUTER-loop) bot identity for the QA runner — the account that
# REVIEWS + MERGES, kept distinct from the inner fixer bot (bot.env) so the bot
# that writes a fix is never the bot that approves it (author ≠ approver, which
# also satisfies "require approval from a non-author" branch protection).
#
# Copy to orchestrator.env (gitignored) and fill in. DO NOT paste the token into
# chat — the watcher reads it from this file. If absent, the outer loop merges as
# your own gh account (backward-compatible).
#
# Create: a SECOND, SEPARATE GitHub account from the fixer bot, add it as a Write
# collaborator on winoooops/vimeflow, then — signed in AS THIS BOT — make a
# CLASSIC PAT with the `repo` scope.
GH_ORCH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx
GH_ORCH_USER=vimeflow-qa-orchestrator
GH_ORCH_EMAIL=youremail+qaorch@example.com
