{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": "../..",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": [
      "node",
      "mocha",
      "@wdio/globals/types",
      "expect-webdriverio",
      "@wdio/electron-service"
    ]
  },
  "include": [
    "**/*.ts",
    "../../src/types/e2e.d.ts",
    "../../src/types/vimeflow.d.ts"
  ]
}
