# Personal Linear API key — for DIRECT GraphQL API calls only (scripts, git hooks, CI).
# The Linear MCP server authenticates via OAuth and does NOT use this key.
#
# Copy to linear.env (gitignored), fill the key, then:  source linear.env
# The `export` propagates the key to child processes, not just your shell.
# Do NOT commit a real key.
# Create at: Linear → Settings → Security & access → Personal API keys
export LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
